APP_NAME=NeuralFlow
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# 短期记忆：Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
WORKING_MEMORY_MAX_TURNS=10

# 长期记忆：ChromaDB
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=conversation_memory

# LLM / Tooling
LITELLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
MCP_BASE_URL=http://localhost:9000

# 可选：如需覆盖默认的 Celery Redis 地址再设置
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/1
